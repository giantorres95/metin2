# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/metin2_guild

# JWT secret for signing access tokens
JWT_SECRET=your-jwt-secret-here

# AES-256-GCM encryption key (32 bytes hex-encoded)
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# JWT secret for signing refresh tokens
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here

# Server port (default: 3000)
PORT=3000

# Node environment (development | production)
NODE_ENV=development
